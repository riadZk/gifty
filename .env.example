APP_NAME="PCC Fidélité"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Database ──────────────────────────────
# ⚠️  Host = nom du service Docker, pas "localhost" !
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pcc_fidelite
DB_USERNAME=pcc_user
DB_PASSWORD=pcc_password_2026

# ─── Redis ─────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Mail (SendGrid) ───────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_SENDGRID_API_KEY
MAIL_FROM_ADDRESS=noreply@tractafric.ma
MAIL_FROM_NAME="Tractafric PCC"

# ─── Firebase (Push Notifications) ─────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
